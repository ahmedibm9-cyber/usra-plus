// USRA PLUS — Prisma Schema (PostgreSQL for production)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  firstName    String?
  lastName     String?
  phone        String?
  countryCode  String?   @default("+966")
  avatarUrl    String?
  language     String    @default("en")
  theme        String    @default("dark")
  emailVerified Boolean  @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions Session[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ─── Subscription Plan Management ─────────────────────────────────

model SubscriptionPlan {
  id              String   @id @default(uuid())
  slug            String   @unique
  name            String
  description     String
  monthlyPrice    Decimal  @default(0) @db.Decimal(10, 2)
  yearlyPrice     Decimal? @db.Decimal(10, 2)
  lifetimePrice   Decimal? @db.Decimal(10, 2)
  currency        String   @default("USD")
  features        Json     @default("[]")
  limits          Json     @default("{}")
  trialDays       Int      @default(0)
  isActive        Boolean  @default(true)
  isPopular       Boolean  @default(false)
  sortOrder       Int      @default(0)
  ctaText         String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Coupons ──────────────────────────────────────────────────────

model Coupon {
  id                    String   @id @default(uuid())
  code                  String   @unique
  name                  String
  description           String   @default("")
  discountType          String   @default("percentage")
  discountValue         Decimal  @default(0) @db.Decimal(10, 2)
  applicablePlans       Json     @default("[]")
  maxRedemptions        Int?
  currentRedemptions    Int      @default(0)
  maxRedemptionsPerUser Int      @default(1)
  validFrom             DateTime?
  validUntil            DateTime?
  isActive              Boolean  @default(true)
  targetAudience        String   @default("all")
  autoApply             Boolean  @default(false)
  createdBy             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  redemptions CouponRedemption[]
}

model CouponRedemption {
  id              String   @id @default(uuid())
  couponId        String
  userId          String
  discountApplied Decimal  @default(0) @db.Decimal(10, 2)
  redeemedAt      DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([userId])
}

// ─── Referrals ────────────────────────────────────────────────────

model Referral {
  id              String   @id @default(uuid())
  referrerId      String
  referralCode    String
  referredEmail   String?
  referredUserId  String?
  status          String   @default("pending")
  rewardType      String   @default("trial_extension")
  rewardValue     Decimal  @default(0) @db.Decimal(10, 2)
  rewardClaimed   Boolean  @default(false)
  rewardClaimedAt DateTime?
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([referralCode])
  @@index([referrerId])
  @@index([referredUserId])
}

// ─── Revenue Transactions ─────────────────────────────────────────

model RevenueTransaction {
  id              String   @id @default(uuid())
  userId          String?
  subscriptionId  String?
  type            String   @default("payment")
  amount          Decimal  @default(0) @db.Decimal(10, 2)
  currency        String   @default("USD")
  originalAmount  Decimal? @db.Decimal(10, 2)
  discountAmount  Decimal  @default(0) @db.Decimal(10, 2)
  couponId        String?
  paymentProvider String?
  status          String   @default("pending")
  description     String?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

// ─── Refunds ──────────────────────────────────────────────────────

model Refund {
  id            String   @id @default(uuid())
  transactionId String
  userId        String?
  amount        Decimal  @default(0) @db.Decimal(10, 2)
  reason        String   @default("")
  category      String   @default("other")
  status        String   @default("pending")
  approvedBy    String?
  approvedAt    DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([transactionId])
  @@index([status])
}

// ─── Campaigns & Marketing ──────────────────────────────────────────

model EmailCampaign {
  id              String   @id @default(uuid())
  name            String
  subject         String
  bodyHtml        String   @default("")
  bodyText        String?
  templateId      String?
  targetSegment   String   @default("all")
  status          String   @default("draft")
  scheduledAt     DateTime?
  sentAt          DateTime?
  totalRecipients Int      @default(0)
  openedCount     Int      @default(0)
  clickedCount    Int      @default(0)
  bouncedCount    Int      @default(0)
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
}

model UserSegment {
  id            String   @id @default(uuid())
  name          String
  description   String   @default("")
  rules         Json     @default("{}")
  userCount     Int      @default(0)
  isAutoUpdate  Boolean  @default(false)
  lastUpdatedAt DateTime?
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ABTest {
  id               String   @id @default(uuid())
  name             String
  featureKey        String
  variantA         String
  variantB         String
  trafficPercentage Int     @default(50)
  status           String   @default("draft")
  targetSegment    String   @default("all")
  startedAt        DateTime?
  endedAt          DateTime?
  winner           String?
  createdBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([featureKey])
}

// ─── Admin Operations ──────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid())
  adminEmail  String
  action      String
  targetType  String   @default("system")
  targetId    String?
  details     Json     @default("{}")
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([action])
  @@index([adminEmail])
  @@index([createdAt])
}

model ModerationItem {
  id          String   @id @default(uuid())
  itemType    String   @default("content_flag")
  status      String   @default("pending")
  priority    String   @default("medium")
  notes       String?
  reportedBy  String?
  assignedTo  String?
  targetId    String?
  reason      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([priority])
}

model SupportTicket {
  id              String    @id @default(uuid())
  subject         String
  description     String    @default("")
  category        String    @default("general")
  status          String    @default("open")
  priority        String    @default("medium")
  userEmail       String?
  userName        String?
  assignedTo      String?
  resolutionNotes String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  resolvedAt      DateTime?

  @@index([status])
  @@index([category])
  @@index([createdAt])
}

model UserBan {
  id               String    @id @default(uuid())
  userId           String
  banType          String    @default("warning")
  status           String    @default("active")
  reason           String
  issuedBy         String?
  expiresAt        DateTime?
  appealText       String?
  appealSubmittedAt DateTime?
  approvedBy       String?
  approvalRequired Boolean   @default(false)
  revokedBy        String?
  revokeReason     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

// ─── Feature Flags (Persistent) ──────────────────────────────────

model FeatureFlag {
  id                String   @id @default(uuid())
  key               String   @unique
  name              String
  description       String   @default("")
  enabled           Boolean  @default(false)
  rolloutPercentage Int      @default(100)
  targetPlan        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([key])
  @@index([enabled])
}

// ─── System Settings (Persistent key-value store) ────────────────

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json     @default("{}")
  updatedAt DateTime @updatedAt

  @@index([key])
}

// ─── Database Backups ────────────────────────────────────────────

model DatabaseBackup {
  id         String   @id @default(uuid())
  filename   String
  fileSize   Int      @default(0)
  tableCount Int      @default(0)
  totalRows  Int      @default(0)
  note       String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

// ─── User Subscriptions (RevenueCat) ──────────────────────────────

model UserSubscription {
  id                    String    @id @default(uuid())
  userId                String
  revenuecatId          String?   @unique
  plan                  String    @default("free")
  status                String    @default("active")
  productIdentifier     String?
  store                 String?
  periodType            String?
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  expirationDate        DateTime?
  autoRenew            Boolean   @default(true)
  isSandbox             Boolean   @default(false)
  cancellationReason    String?
  price                 Decimal?  @db.Decimal(10, 2)
  currency              String?   @default("USD")
  lastRevenuecatEvent   String?
  lastEventAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([plan])
  @@index([revenuecatId])
}

// ─── Verification Codes (OTP) ──────────────────────────────────────

model VerificationCode {
  id        String    @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([code])
  @@index([expiresAt])
}

// ─── Families ──────────────────────────────────────────────────────

model Family {
  id          String   @id @default(uuid())
  name        String
  description String?
  inviteCode  String   @unique
  avatarUrl   String?
  color       String   @default("signal")
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members FamilyMember[]

  @@index([createdBy])
  @@index([inviteCode])
}

model FamilyMember {
  id       String   @id @default(uuid())
  familyId String
  userId   String
  role     String   @default("member")
  nickname String?
  joinedAt DateTime @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
  @@index([familyId])
  @@index([userId])
}

// ─── System Health Monitoring (from incoming) ──────────────────────

model SystemHealth {
  id            String   @id @default(uuid())
  service       String
  status        String   @default("operational")
  responseTime  Int?
  uptime        Float?
  lastCheckedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([service])
}

// ─── Bug Reports (from incoming) ────────────────────────────────────

model BugReport {
  id          String   @id @default(uuid())
  title       String
  description String?
  severity    String   @default("medium")
  status      String   @default("open")
  source      String   @default("auto")
  stackTrace  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([severity])
}

// ─── Platform Stats (from incoming) ─────────────────────────────────

model PlatformStats {
  id              String   @id @default(uuid())
  totalUsers      Int      @default(0)
  activeUsers     Int      @default(0)
  totalDevices    Int      @default(0)
  totalAlerts     Int      @default(0)
  revenue         Float    @default(0)
  timestamp       DateTime @default(now())
}
