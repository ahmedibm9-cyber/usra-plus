// USRA PLUS — Prisma Schema
// Production-ready: PostgreSQL only (Supabase)
// Development: Use Supabase local or set DATABASE_URL to PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  firstName    String?
  lastName     String?
  phone        String?
  countryCode  String?   @default("+966")
  avatarUrl    String?
  language     String    @default("en")
  theme        String    @default("dark")
  emailVerified Boolean  @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions            Session[]
  subscriptions      UserSubscription[]
  couponRedemptions  CouponRedemption[]
  familyMembers      FamilyMember[]
  referrals           Referral[]          @relation("UserReferrals")
  referredReferrals   Referral[]          @relation("UserReferredBy")
  revenueTransactions RevenueTransaction[]
  consents            Consent[]
  bans                UserBan[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model SubscriptionPlan {
  id              String   @id @default(uuid())
  slug            String   @unique
  name            String
  description     String
  monthlyPrice    Decimal  @default(0) @db.Decimal(10,2)
  yearlyPrice     Decimal? @db.Decimal(10,2)
  lifetimePrice   Decimal? @db.Decimal(10,2)
  currency        String   @default("USD")
  features        String   @default("[]")
  limits          String   @default("{}")
  trialDays       Int      @default(0)
  isActive        Boolean  @default(true)
  isPopular       Boolean  @default(false)
  sortOrder       Int      @default(0)
  ctaText         String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Coupon {
  id                    String    @id @default(uuid())
  code                  String    @unique
  name                  String
  description           String    @default("")
  discountType          String    @default("percentage")
  discountValue         Decimal   @default(0) @db.Decimal(10,2)
  applicablePlans       String    @default("[]")
  maxRedemptions        Int?
  currentRedemptions    Int       @default(0)
  maxRedemptionsPerUser Int       @default(1)
  validFrom             DateTime?
  validUntil            DateTime?
  isActive              Boolean   @default(true)
  targetAudience        String    @default("all")
  autoApply             Boolean   @default(false)
  createdBy             String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  redemptions CouponRedemption[]
  revenueTransactions RevenueTransaction[]
}

model CouponRedemption {
  id              String   @id @default(uuid())
  couponId        String
  userId          String
  discountApplied Decimal  @default(0) @db.Decimal(10,2)
  redeemedAt      DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([userId])
}

model Referral {
  id              String    @id @default(uuid())
  referrerId      String
  referralCode    String
  referredEmail   String?
  referredUserId  String?
  status          String    @default("pending")
  rewardType      String    @default("trial_extension")
  rewardValue     Decimal   @default(0) @db.Decimal(10,2)
  rewardClaimed   Boolean   @default(false)
  rewardClaimedAt DateTime?
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  referrer    User  @relation("UserReferrals", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser User? @relation("UserReferredBy", fields: [referredUserId], references: [id], onDelete: SetNull)

  @@index([referralCode])
  @@index([referrerId])
  @@index([referredUserId])
}

model RevenueTransaction {
  id              String    @id @default(uuid())
  userId          String?
  subscriptionId  String?
  type            String    @default("payment")
  amount          Decimal   @default(0) @db.Decimal(10,2)
  currency        String    @default("USD")
  originalAmount  Decimal?  @db.Decimal(10,2)
  discountAmount  Decimal   @default(0) @db.Decimal(10,2)
  couponId        String?
  paymentProvider String?
  status          String    @default("pending")
  description     String?
  createdAt       DateTime  @default(now())

  user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon  Coupon? @relation(fields: [couponId], references: [id], onDelete: SetNull)
  refunds Refund[]

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model Refund {
  id            String    @id @default(uuid())
  transactionId String
  userId        String?
  amount        Decimal   @default(0) @db.Decimal(10,2)
  reason        String    @default("")
  category      String    @default("other")
  status        String    @default("pending")
  approvedBy    String?
  approvedAt    DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  transaction RevenueTransaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([status])
}

model EmailCampaign {
  id              String    @id @default(uuid())
  name            String
  subject         String
  bodyHtml        String    @default("")
  bodyText        String?
  templateId      String?
  targetSegment   String    @default("all")
  status          String    @default("draft")
  scheduledAt     DateTime?
  sentAt          DateTime?
  totalRecipients Int       @default(0)
  openedCount     Int       @default(0)
  clickedCount    Int       @default(0)
  bouncedCount    Int       @default(0)
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
}

model UserSegment {
  id            String    @id @default(uuid())
  name          String
  description   String    @default("")
  rules         String    @default("{}")
  userCount     Int       @default(0)
  isAutoUpdate  Boolean   @default(false)
  lastUpdatedAt DateTime?
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ABTest {
  id               String    @id @default(uuid())
  name             String
  featureKey        String
  variantA         String
  variantB         String
  trafficPercentage Int      @default(50)
  status           String    @default("draft")
  targetSegment    String    @default("all")
  startedAt        DateTime?
  endedAt          DateTime?
  winner           String?
  createdBy        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([featureKey])
}

model AuditLog {
  id          String   @id @default(uuid())
  adminEmail  String
  action      String
  targetType  String   @default("system")
  targetId    String?
  details     String   @default("{}")
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([action])
  @@index([adminEmail])
  @@index([createdAt])
}

model ModerationItem {
  id          String    @id @default(uuid())
  itemType    String    @default("content_flag")
  status      String    @default("pending")
  priority    String    @default("medium")
  notes       String?
  reportedBy  String?
  assignedTo  String?
  targetId    String?
  reason      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([priority])
}

model SupportTicket {
  id              String    @id @default(uuid())
  subject         String
  description     String    @default("")
  category        String    @default("general")
  status          String    @default("open")
  priority        String    @default("medium")
  userEmail       String?
  userName        String?
  assignedTo      String?
  resolutionNotes String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  resolvedAt      DateTime?

  @@index([status])
  @@index([category])
  @@index([createdAt])
}

model UserBan {
  id               String    @id @default(uuid())
  userId           String
  banType          String    @default("warning")
  status           String    @default("active")
  reason           String
  issuedBy         String?
  expiresAt        DateTime?
  appealText       String?
  appealSubmittedAt DateTime?
  approvedBy       String?
  approvalRequired Boolean   @default(false)
  revokedBy        String?
  revokeReason     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model FeatureFlag {
  id                String   @id @default(uuid())
  key               String   @unique
  name              String
  description       String   @default("")
  enabled           Boolean  @default(false)
  rolloutPercentage Int      @default(100)
  targetPlan        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([key])
  @@index([enabled])
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @default("{}")
  updatedAt DateTime @updatedAt

  @@index([key])
}

model DatabaseBackup {
  id         String   @id @default(uuid())
  filename   String
  fileSize   Int      @default(0)
  tableCount Int      @default(0)
  totalRows  Int      @default(0)
  note       String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model UserSubscription {
  id                    String    @id @default(uuid())
  userId                String
  plan                  String    @default("free")
  status                String    @default("active")
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  trialStart            DateTime?
  trialEnd              DateTime?
  autoRenew            Boolean   @default(true)
  cancellationReason    String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([plan])
}

model Consent {
  id        String   @id @default(uuid())
  userId    String
  type      String
  granted   Boolean
  version   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

model VerificationCode {
  id        String    @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([code])
  @@index([expiresAt])
}

model Family {
  id          String   @id @default(uuid())
  name        String
  description String?
  inviteCode  String   @unique
  avatarUrl   String?
  color       String   @default("signal")
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members FamilyMember[]

  @@index([createdBy])
  @@index([inviteCode])
}

model FamilyMember {
  id       String   @id @default(uuid())
  familyId String
  userId   String
  role     String   @default("member")
  nickname String?
  joinedAt DateTime @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
  @@index([familyId])
  @@index([userId])
}

model SystemHealth {
  id            String   @id @default(uuid())
  service       String
  status        String   @default("operational")
  responseTime  Int?
  uptime        Float?
  lastCheckedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([service])
}

model BugReport {
  id          String   @id @default(uuid())
  title       String
  description String?
  severity    String   @default("medium")
  status      String   @default("open")
  source      String   @default("auto")
  stackTrace  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([severity])
}

model PlatformStats {
  id              String   @id @default(uuid())
  totalUsers      Int      @default(0)
  activeUsers     Int      @default(0)
  totalDevices    Int      @default(0)
  totalAlerts     Int      @default(0)
  revenue         Decimal  @default(0) @db.Decimal(10,2)
  timestamp       DateTime @default(now())
}

model SubscriptionOtp {
  id           String    @id @default(uuid())
  code         String    @unique
  userId       String
  planSlug     String
  startDate    DateTime
  endDate      DateTime
  generatedBy  String
  status       String    @default("pending")
  usedAt       DateTime?
  createdAt    DateTime  @default(now())
  expiresAt    DateTime

  @@index([code])
  @@index([userId])
  @@index([status])
}

model AdminOtpAction {
  id           String   @id @default(uuid())
  adminId      String
  action       String
  otpId        String
  targetUserId String
  details      String   @default("{}")
  createdAt    DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}
