# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === Admin Auth (Required for admin panel) ===
ADMIN_SECRET_KEY=usra-admin-secret-key-prod-2024-xf7k9m2p
ADMIN_SESSION_SECRET=usra-session-secret-prod-2024-hd3n8q1w
ADMIN_PASSWORD=usra2024admin
ADMIN_EMAIL=admin@usraplus.com

